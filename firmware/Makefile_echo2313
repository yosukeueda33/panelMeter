MCU       = attiny2313
PART      = t2313
F_CPU     = 10000000UL
BAUD      = 9600

TARGET    = echo2313

CC        = avr-gcc
OBJCOPY   = avr-objcopy
AVRDUDE   = avrdude

PROGRAMMER = avrispmkII

GEN_DIR   = generated

CFLAGS = \
	-mmcu=$(MCU) \
	-DF_CPU=$(F_CPU) \
	-DBAUD=$(BAUD) \
	-Os \
	-std=c11 \
	-Wall \
	-Wextra \
	-ffunction-sections \
	-fdata-sections \
	-I. \
	-I$(GEN_DIR)

LDFLAGS = \
	-mmcu=$(MCU) \
	-Wl,--gc-sections

SRCS = \
	infra.c \
	echo2313.c \
	$(GEN_DIR)/Communicate.c\
	$(GEN_DIR)/copilot_cords.c

OBJS = $(SRCS:.c=.o)

.PHONY: all generate flash clean size disasm

all: generate $(TARGET).hex size

generate:
	cd ../copilot-gen && stack run
	cd ../ivory-gen && stack run
	mkdir -p $(GEN_DIR)
	cp ../copilot-gen/copilot_cords_types.h $(GEN_DIR)/
	cp ../copilot-gen/copilot_cords.h $(GEN_DIR)/
	cp ../copilot-gen/copilot_cords.c $(GEN_DIR)/
	cp ../ivory-gen/generated/Communicate.c $(GEN_DIR)/
	cp ../ivory-gen/generated/Communicate.h $(GEN_DIR)/
	cp ../ivory-gen/generated/ivory.h $(GEN_DIR)/
	cp ../ivory-gen/generated/ivory_asserts.h $(GEN_DIR)/
	cp ../ivory-gen/generated/ivory_templates.h $(GEN_DIR)/

$(TARGET).elf: $(OBJS)
	$(CC) $(LDFLAGS) -o $@ $(OBJS)

$(TARGET).hex: $(TARGET).elf
	$(OBJCOPY) -O ihex -R .eeprom $< $@

%.o: %.c
	$(CC) $(CFLAGS) -c -o $@ $<

flash: $(TARGET).hex
	$(AVRDUDE) -c $(PROGRAMMER) -p $(PART) -U flash:w:$(TARGET).hex:i

size: $(TARGET).elf
	avr-size -C --mcu=$(MCU) $(TARGET).elf

disasm: $(TARGET).elf
	avr-objdump -d $(TARGET).elf > $(TARGET).lst

clean:
	rm -f $(TARGET).elf $(TARGET).hex $(TARGET).lst
	rm -f $(OBJS)